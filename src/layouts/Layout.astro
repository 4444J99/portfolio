---
import { ClientRouter } from 'astro:transitions';
import BackToTop from '../components/BackToTop.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BaseMeta from '../components/head/BaseMeta.astro';
import FaviconLinks from '../components/head/FaviconLinks.astro';
import FontFaces from '../components/head/FontFaces.astro';
import SchemaOrg from '../components/head/SchemaOrg.astro';
import SEOMeta from '../components/head/SEOMeta.astro';
import SiteLinks from '../components/head/SiteLinks.astro';
import ClientBootstrap from '../components/scripts/ClientBootstrap.astro';
import ErrorBeacon from '../components/scripts/ErrorBeacon.astro';
import ScrollReveal from '../components/scripts/ScrollReveal.astro';
import ShibuiRestore from '../components/scripts/ShibuiRestore.astro';
import SketchLifecycle from '../components/scripts/SketchLifecycle.astro';
import ThemeRestore from '../components/scripts/ThemeRestore.astro';
import WebVitals from '../components/scripts/WebVitals.astro';
import ShibuiGlint from '../components/shibui/ShibuiGlint.astro';
import { canonicalBase } from '../utils/paths';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	mainClass?: string;
	mainAttrs?: Record<string, string>;
	schemaProject?: {
		name: string;
		description: string;
		tags: string[];
		repo?: string;
		liveUrl?: string;
	};
	keywords?: string[];
	/** Minimum shibui depth for this page (e.g. 'standard' prevents overview mode) */
	shibuiFloor?: 'overview' | 'standard' | 'full';
}

const slug = Astro.url.pathname.replace(/^\/portfolio\//, '').replace(/\/$/, '') || 'index';
const defaultOG = `${canonicalBase}/og/${slug}.png`;
const {
	title,
	description = 'Creative technologist building autonomous creative systems and treating governance as artistic medium.',
	ogImage = defaultOG,
	mainClass,
	mainAttrs = {},
	schemaProject,
	keywords = [],
	shibuiFloor,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://4444j99.github.io').href;
---

<!doctype html>
<html lang="en" {...(shibuiFloor ? { 'data-shibui-page-floor': shibuiFloor } : {})}>
  <head>
    <BaseMeta description={description} canonicalURL={canonicalURL} />
    <FaviconLinks />
    <SiteLinks />
    <SEOMeta title={title} description={description} canonicalURL={canonicalURL} ogImage={ogImage} ogType={schemaProject ? 'article' : 'website'} keywords={keywords} />
    <SchemaOrg description={description} ogImage={ogImage} project={schemaProject} />
    <FontFaces />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to main content</a>
    <div id="bg-canvas" aria-hidden="true" transition:persist></div>
    <Header />
    <main id="main-content" class:list={[mainClass]} {...mainAttrs}>
      <slot />
    </main>
    <Footer />
    <BackToTop />
  </body>
  <SketchLifecycle />
  <ScrollReveal />
  <ClientBootstrap />
  <ThemeRestore />
  <ShibuiRestore />
  <ShibuiGlint />
  <WebVitals />
  <ErrorBeacon />
</html>

<style is:global>
  @import '../styles/global.css';
</style>
