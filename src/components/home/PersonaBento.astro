---
import { base } from '../../utils/paths';

interface Persona {
	id: string;
	slug: string;
	title: string;
}

interface Props {
	personas: Persona[];
}

const { personas } = Astro.props;
---

<div class="persona-bento" data-reveal>
	<h3 class="persona-bento__heading">Tailored Resumes</h3>
	<ul class="persona-bento__list">
		{personas.map((p) => (
			<li class="persona-bento__item">
				<a class="persona-bento__link" href={`${base}resume/${p.slug}/`}>
					<span class="persona-bento__title">{p.title}</span>
					<svg
						class="persona-bento__arrow"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<line x1="5" y1="12" x2="19" y2="12" />
						<polyline points="12 5 19 12 12 19" />
					</svg>
				</a>
			</li>
		))}
	</ul>
</div>

<style>
	.persona-bento {
		grid-column: span 4;
		background: var(--bg-card);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-lg);
	}

	.persona-bento__heading {
		font-family: var(--font-heading);
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--accent-text);
		margin-bottom: var(--space-md);
	}

	.persona-bento__list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.persona-bento__link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-sm);
		padding: var(--space-sm) var(--space-xs);
		border-radius: var(--radius-sm);
		text-decoration: none;
		color: var(--text-secondary);
		transition:
			color var(--transition-fast),
			background var(--transition-fast);
	}

	.persona-bento__link:hover {
		color: var(--accent-text);
		background: var(--accent-muted);
	}

	.persona-bento__title {
		font-size: 0.9rem;
		line-height: 1.4;
	}

	.persona-bento__arrow {
		flex-shrink: 0;
		opacity: 0;
		transform: translateX(-4px);
		transition:
			opacity var(--transition-fast),
			transform var(--transition-fast);
	}

	.persona-bento__link:hover .persona-bento__arrow {
		opacity: 1;
		transform: translateX(0);
	}

	@media (max-width: 768px) {
		.persona-bento {
			grid-column: span 1;
		}
	}
</style>
