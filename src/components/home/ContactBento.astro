---
import { base } from '../../utils/paths';
---

<div class="contact-bento" data-reveal>
	<h3 class="contact-bento__heading">Let's work together</h3>
	<p class="contact-bento__text">
		Available for consulting, architecture reviews, and strategic technical guidance.
	</p>
	<a href={`${base}consult/`} class="contact-bento__btn">
		Start a conversation
	</a>
	<div class="contact-bento__links">
		<a
			href="mailto:padavano.anthony@gmail.com"
			class="contact-bento__link"
			aria-label="Email"
		>
			<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<rect x="2" y="4" width="20" height="16" rx="2" />
				<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
			</svg>
			<span class="contact-bento__link-label">padavano.anthony@gmail.com</span>
		</a>
		<a
			href="https://www.linkedin.com/in/anthony-james-padavano-98a40a186/"
			target="_blank"
			rel="me noopener noreferrer"
			class="contact-bento__link"
			aria-label="LinkedIn"
		>
			<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
				<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
			</svg>
			<span class="contact-bento__link-label">LinkedIn</span>
		</a>
		<a
			href="https://github.com/4444j99"
			target="_blank"
			rel="me noopener noreferrer"
			class="contact-bento__link"
			aria-label="GitHub"
		>
			<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
				<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
			</svg>
			<span class="contact-bento__link-label">GitHub</span>
		</a>
	</div>
</div>

<style>
	.contact-bento {
		grid-column: span 4;
		grid-row: span 2;
		background: var(--bg-card);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-xl);
		display: flex;
		flex-direction: column;
	}

	.contact-bento__heading {
		font-family: var(--font-heading);
		font-size: 1.35rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: var(--space-sm);
	}

	.contact-bento__text {
		font-size: 0.95rem;
		line-height: 1.6;
		color: var(--text-secondary);
		margin-bottom: var(--space-lg);
	}

	.contact-bento__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-sm) var(--space-xl);
		background: var(--accent);
		color: #000;
		font-weight: 600;
		font-size: 0.9rem;
		text-decoration: none;
		border-radius: 100px;
		transition:
			background var(--transition-fast),
			transform var(--transition-fast);
		margin-bottom: var(--space-xl);
	}

	.contact-bento__btn:hover {
		background: var(--accent-hover);
		color: #fff;
		transform: translateY(-1px);
	}

	.contact-bento__links {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		margin-top: auto;
	}

	.contact-bento__link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-sm);
		font-size: 0.85rem;
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.contact-bento__link:hover {
		color: var(--accent-text);
	}

	@media (max-width: 768px) {
		.contact-bento {
			grid-column: span 1;
			grid-row: span 1;
		}

		.contact-bento__link-label {
			display: none;
		}

		.contact-bento__links {
			flex-direction: row;
			gap: var(--space-lg);
		}
	}
</style>
