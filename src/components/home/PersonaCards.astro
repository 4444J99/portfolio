---
import { base } from '../../utils/paths';

interface Persona {
	id: string;
	title: string;
	thesis: string;
}

interface Props {
	personas: Persona[];
}

const { personas } = Astro.props;
---

<section class="persona-cards section">
	<div class="container">
		<h2 class="persona-cards__heading">Looking for a specific role?</h2>
		<div class="persona-cards__grid" data-reveal>
			{personas.map((persona) => (
				<a href={`${base}resume/${persona.id}/`} class="persona-cards__item">
					<h3 class="persona-cards__title">{persona.title}</h3>
					<p class="persona-cards__thesis">{persona.thesis}</p>
					<span class="persona-cards__link" aria-hidden="true">View resume &rarr;</span>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.persona-cards {
		padding: var(--space-3xl) 0;
		border-bottom: 1px solid var(--border);
	}

	.persona-cards__heading {
		font-family: var(--font-heading);
		margin-bottom: var(--space-xl);
	}

	.persona-cards__grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-lg);
	}

	.persona-cards__item {
		display: flex;
		flex-direction: column;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-xl);
		text-decoration: none;
		color: inherit;
		transition:
			border-color var(--transition-base),
			box-shadow var(--transition-base);
	}

	.persona-cards__item:hover {
		border-color: var(--accent);
		box-shadow: 0 4px 24px rgba(212, 168, 83, 0.1);
	}

	.persona-cards__title {
		font-family: var(--font-heading);
		font-size: 1.05rem;
		color: var(--text-primary);
		margin-bottom: var(--space-sm);
	}

	.persona-cards__thesis {
		font-size: 0.875rem;
		line-height: 1.6;
		color: var(--text-secondary);
		flex: 1;
	}

	.persona-cards__link {
		display: inline-block;
		margin-top: var(--space-md);
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--accent-text);
		transition: color var(--transition-fast);
	}

	.persona-cards__item:hover .persona-cards__link {
		color: var(--accent-hover);
	}

	@media (max-width: 768px) {
		.persona-cards__grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
