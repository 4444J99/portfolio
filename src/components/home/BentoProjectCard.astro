---
interface Props {
	title: string;
	tagline: string;
	description?: string;
	href: string;
	tags: string[];
	slug: string;
	organ?: string;
}

const { title, tagline, description, href, tags, slug, organ } = Astro.props;
---

<div
	class="bento-card"
	role="button"
	tabindex="0"
	data-expandable
	aria-expanded="false"
	data-reveal
	transition:name={`project-${slug}`}
>
	<div class="bento-card__header">
		<h3 class="bento-card__title">{title}</h3>
		{organ && <span class="bento-card__organ">{organ}</span>}
		<span class="bento-card__indicator" aria-hidden="true">+</span>
	</div>
	<div class="bento-card__detail">
		<div class="bento-card__detail-inner">
			<p class="bento-card__tagline">{tagline}</p>
			{description && <p class="bento-card__description">{description}</p>}
			{tags.length > 0 && (
				<div class="bento-card__tags">
					{tags.map((tag) => (
						<span class="bento-card__tag">{tag}</span>
					))}
				</div>
			)}
			<a class="bento-card__link" href={href}>
				View case study <span aria-hidden="true">&rarr;</span>
			</a>
		</div>
	</div>
</div>

<style>
	.bento-card {
		grid-column: span 3;
		display: flex;
		flex-direction: column;
		background: var(--bg-card);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-md);
		color: var(--text-primary);
		cursor: pointer;
		overflow: hidden;
		transition:
			border-color var(--transition-base),
			transform var(--transition-base),
			box-shadow var(--transition-base);
	}

	.bento-card:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
	}

	.bento-card:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.bento-card[data-expanded] {
		grid-column: span 6;
		grid-row: span 2;
		padding: var(--space-lg);
		border-color: var(--accent);
		box-shadow: var(--shadow-lg);
	}

	.bento-card__header {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		min-height: 0;
	}

	.bento-card__title {
		font-family: var(--font-heading);
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--text-primary);
		line-height: 1.3;
		flex: 1;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.bento-card[data-expanded] .bento-card__title {
		font-size: 1.2rem;
		white-space: normal;
		overflow: visible;
	}

	.bento-card__organ {
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		flex-shrink: 0;
	}

	.bento-card__indicator {
		font-size: 1rem;
		color: var(--text-muted);
		flex-shrink: 0;
		transition: transform var(--transition-fast);
		line-height: 1;
	}

	.bento-card[data-expanded] .bento-card__indicator {
		transform: rotate(45deg);
	}

	.bento-card__detail {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows var(--transition-base);
	}

	.bento-card[data-expanded] .bento-card__detail {
		grid-template-rows: 1fr;
	}

	.bento-card__detail-inner {
		overflow: hidden;
	}

	.bento-card__tagline {
		font-size: 0.85rem;
		line-height: 1.5;
		color: var(--text-secondary);
		margin-top: var(--space-sm);
		margin-bottom: var(--space-sm);
	}

	.bento-card__description {
		font-size: 0.8rem;
		line-height: 1.6;
		color: var(--text-muted);
		margin-bottom: var(--space-md);
	}

	.bento-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
		margin-bottom: var(--space-md);
	}

	.bento-card__tag {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 0.15em 0.55em;
		border: 1px solid var(--border);
		border-radius: 100px;
		color: var(--text-muted);
	}

	.bento-card__link {
		display: inline-block;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.bento-card__link:hover {
		color: var(--accent-hover);
	}

	@media (max-width: 768px) {
		.bento-card {
			grid-column: span 1;
		}

		.bento-card[data-expanded] {
			grid-column: span 1;
			grid-row: span 1;
		}
	}
</style>

<script>
	function initBentoCards() {
		const cards = document.querySelectorAll<HTMLElement>('.bento-card[data-expandable]');
		for (const card of cards) {
			card.addEventListener('click', (e) => {
				// Don't toggle if clicking the case study link
				if ((e.target as HTMLElement).closest('.bento-card__link')) return;

				const wasExpanded = card.hasAttribute('data-expanded');
				// Collapse all (accordion)
				for (const c of cards) {
					c.removeAttribute('data-expanded');
					c.setAttribute('aria-expanded', 'false');
				}
				// Toggle clicked
				if (!wasExpanded) {
					card.setAttribute('data-expanded', '');
					card.setAttribute('aria-expanded', 'true');
				}
			});
			card.addEventListener('keydown', (e) => {
				if (e.key === 'Enter' || e.key === ' ') {
					// Don't toggle if focus is on the link
					if ((e.target as HTMLElement).closest('.bento-card__link')) return;
					e.preventDefault();
					card.click();
				}
			});
		}
	}
	document.addEventListener('astro:page-load', initBentoCards);
</script>
