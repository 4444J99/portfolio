---
interface Props {
	title: string;
	tagline: string;
	href: string;
	tags: string[];
	size: 'large' | 'medium' | 'small';
	slug: string;
}

const { title, tagline, href, tags, size, slug } = Astro.props;

const maxTags = size === 'small' ? 2 : tags.length;
const displayTags = tags.slice(0, maxTags);
---

<a
	class:list={['bento-card', `bento-card--${size}`]}
	href={href}
	data-reveal
	transition:name={`project-${slug}`}
>
	<h3 class="bento-card__title">{title}</h3>
	<p class="bento-card__tagline">{tagline}</p>
	{displayTags.length > 0 && (
		<div class="bento-card__tags">
			{displayTags.map((tag) => (
				<span class="bento-card__tag">{tag}</span>
			))}
		</div>
	)}
</a>

<style>
	.bento-card {
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		background: var(--bg-card);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-lg);
		text-decoration: none;
		color: var(--text-primary);
		transition:
			border-color var(--transition-base),
			transform var(--transition-base);
	}

	.bento-card:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
	}

	.bento-card--large {
		grid-column: span 4;
		grid-row: span 2;
		padding: var(--space-xl);
	}

	.bento-card--medium {
		grid-column: span 4;
	}

	.bento-card--small {
		grid-column: span 3;
	}

	.bento-card__title {
		font-family: var(--font-heading);
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--text-primary);
		margin-bottom: var(--space-xs);
		line-height: 1.3;
	}

	.bento-card--large .bento-card__title {
		font-size: 1.35rem;
	}

	.bento-card__tagline {
		font-size: 0.85rem;
		line-height: 1.5;
		color: var(--text-secondary);
		margin-bottom: var(--space-sm);
	}

	.bento-card--small .bento-card__tagline {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.bento-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
		margin-top: auto;
	}

	.bento-card__tag {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 0.15em 0.55em;
		border: 1px solid var(--border);
		border-radius: 100px;
		color: var(--text-muted);
	}

	@media (max-width: 768px) {
		.bento-card--large,
		.bento-card--medium,
		.bento-card--small {
			grid-column: span 1;
			grid-row: span 1;
		}

		.bento-card--large .bento-card__title {
			font-size: 1.1rem;
		}

		.bento-card {
			flex-direction: row;
			align-items: center;
			gap: var(--space-md);
			padding: var(--space-md);
		}

		.bento-card__title {
			flex-shrink: 0;
		}

		.bento-card__tagline {
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
			margin-bottom: 0;
		}

		.bento-card__tags {
			display: none;
		}
	}
</style>
