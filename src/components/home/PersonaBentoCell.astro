---
// src/components/home/PersonaBentoCell.astro
// Compact persona links cell (1x2 tall) for bento grid.

import personasData from '../../data/personas.json';
import { base } from '../../utils/paths';

const personas = personasData.personas;
---

<div class="bento-cell bento-cell--row-2 persona-cell">
	<span class="persona-cell__label">I work as</span>
	<nav class="persona-cell__list" aria-label="Resume personas">
		{
			personas.map((p) => (
				<a href={`${base}resume/${p.id}/`} class="persona-cell__link">
					<span class="persona-cell__title">{p.title}</span>
					<span class="persona-cell__arrow" aria-hidden="true">
						&rarr;
					</span>
				</a>
			))
		}
	</nav>
</div>

<style>
	.persona-cell {
		display: flex;
		flex-direction: column;
	}

	.persona-cell__label {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-muted);
		margin-bottom: var(--space-sm);
	}

	.persona-cell__list {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.persona-cell__link {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: var(--space-xs) var(--space-sm);
		border-radius: var(--radius-sm);
		text-decoration: none;
		color: var(--text-secondary);
		transition: all var(--transition-fast);
	}

	.persona-cell__link:hover {
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		color: var(--accent);
	}

	.persona-cell__title {
		font-size: 0.85rem;
		line-height: 1.3;
	}

	.persona-cell__arrow {
		font-size: 0.85rem;
		color: var(--text-muted);
		transition: transform var(--transition-fast);
	}

	.persona-cell__link:hover .persona-cell__arrow {
		transform: translateX(3px);
		color: var(--accent);
	}
</style>
