---
import healthData from '../../data/workspace-health.json';

interface RepoHealth {
	name: string;
	owner: string;
	lastCommit: string | null;
	buildStatus: string | null;
	testCount: number | null;
	coverage: number | null;
	url: string;
}

const repos = healthData.repos as RepoHealth[];
const lastSync = healthData.lastSync;

function formatDate(iso: string | null): string {
	if (!iso) return '—';
	const d = new Date(iso);
	return d.toLocaleDateString('en-US', {
		month: 'short',
		day: 'numeric',
		year: 'numeric',
		timeZone: 'UTC',
	});
}

function statusBadge(status: string | null): string {
	if (!status) return '○ unknown';
	if (status === 'success') return '● passing';
	if (status === 'failure') return '● failing';
	return `○ ${status}`;
}

function statusClass(status: string | null): string {
	if (!status) return 'status--unknown';
	if (status === 'success') return 'status--pass';
	if (status === 'failure') return 'status--fail';
	return 'status--unknown';
}
---

<section class="workspace-health">
  <h3>Workspace Health</h3>
  <p class="sync-time">Last synced: {formatDate(lastSync)}</p>
  <div class="health-grid">
    {repos.map((repo) => (
      <a href={repo.url} class="health-card" target="_blank" rel="noopener noreferrer">
        <span class="health-card__name">{repo.name}</span>
        <span class={`health-card__status ${statusClass(repo.buildStatus)}`}>
          {statusBadge(repo.buildStatus)}
        </span>
        <span class="health-card__commit">{formatDate(repo.lastCommit)}</span>
        {repo.testCount !== null && (
          <span class="health-card__tests">{repo.testCount} tests</span>
        )}
        {repo.coverage !== null && (
          <span class="health-card__coverage">{repo.coverage}% cov</span>
        )}
      </a>
    ))}
  </div>
</section>

<style>
  .workspace-health {
    margin-top: var(--space-xl);
  }

  .workspace-health h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
  }

  .sync-time {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: var(--space-md);
  }

  .health-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-sm);
  }

  .health-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: var(--space-sm);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }

  .health-card:hover {
    border-color: var(--accent);
  }

  .health-card__name {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .health-card__status {
    font-size: 0.75rem;
  }

  .status--pass {
    color: #4ade80;
  }

  .status--fail {
    color: #f87171;
  }

  .status--unknown {
    color: var(--text-muted);
  }

  .health-card__commit,
  .health-card__tests,
  .health-card__coverage {
    font-size: 0.7rem;
    color: var(--text-muted);
  }
</style>
