				<tr><td>Gold</td><td>5 essays, community health files, orchestration</td><td>~22K</td><td>~10 hours</td></tr>
				<tr><td>Gap-Fill</td><td>13 additional READMEs, orchestration flagship</td><td>~18K</td><td>~6 hours</td></tr>
			</tbody>
		</table>
	</div>

