<ProjectLayout
	pageTitle="AI-Conductor Model — 4444j"
	description={`The methodology for human-AI co-creation that produced ~${wordsK}K words of documentation — AI generates volume, human directs and refines.`}
	sketchId="conductor"
	title="AI-Conductor Model"
	tagline="Human-AI co-creation as artistic practice"
