---
import BentoGrid from '../components/home/BentoGrid.astro';
import ConsultCTA from '../components/home/ConsultCTA.astro';
import ControlsBentoCell from '../components/home/ControlsBentoCell.astro';
import FeaturedBentoCard from '../components/home/FeaturedBentoCard.astro';
import HeroBentoCell from '../components/home/HeroBentoCell.astro';
import IndexFilters from '../components/home/IndexFilters.astro';
import ProjectGrid from '../components/home/ProjectGrid.astro';
import { organColorMap } from '../data/organ-colors';
import { categoryFilters, featuredNumbers, organGroups, skillFilters } from '../data/organ-groups';
import Layout from '../layouts/Layout.astro';
import { base } from '../utils/paths';

// Resolve slugs to full hrefs at build time
const resolvedGroups = organGroups.map((group) => ({
	...group,
	projects: group.projects.map((p) => ({ ...p, href: `${base}projects/${p.slug}/` })),
}));

const allProjects = resolvedGroups.flatMap((g) =>
	g.projects.map((p) => ({ ...p, organ: g.name, organColor: organColorMap[g.organ] || 'var(--accent)' })),
);
const featured = allProjects.filter((p) => featuredNumbers.has(p.number)).slice(0, 2);
---

<Layout
	title="Anthony James Padavano — AI Orchestration Architect"
	description="Portfolio of Anthony James Padavano — AI Orchestration Architect, Systems Engineer, and Creative Technologist building a 91-repository autonomous creative-institutional system."
	mainAttrs={{ 'data-portfolio-view': 'engineering' }}
	keywords={['AI Orchestration', 'Systems Architect', 'Platform Governance', 'Logocentric Architecture', 'Staff Engineer', 'Multi-Agent Systems', 'Python', 'TypeScript', 'CI/CD Automation']}
>
    <BentoGrid>
      <HeroBentoCell />
      <ControlsBentoCell />
      {featured.map((p) => (
        <FeaturedBentoCard
          title={p.title}
          tagline={p.tagline}
          slug={p.slug}
          tags={p.tags}
          skills={p.skills}
          organ={p.organ}
          organColor={p.organColor}
        />
      ))}
    </BentoGrid>

    <ProjectGrid
      resolvedGroups={resolvedGroups}
      skillFilters={skillFilters}
      categoryFilters={categoryFilters}
      featuredNumbers={featuredNumbers}
      organColorMap={organColorMap}
    />

    <div class="home-pair home-pair--bottom">
      <ConsultCTA />
      <section class="home-pair__contact" id="contact">
        <h2 class="section__heading">Strategic Orchestration</h2>
        <p class="contact__text">
          I bridge 15 years of high-stakes delivery with modern system orchestration. I am available for Staff and Director-level roles in AI Infrastructure, Systems Architecture, and Creative R&D.
        </p>
        <div class="contact__links">
          <a href="mailto:padavano.anthony@gmail.com" class="contact__link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            padavano.anthony@gmail.com
          </a>
          <a href="https://www.linkedin.com/in/anthony-james-padavano-98a40a186/" target="_blank" rel="me noopener noreferrer" class="contact__link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href="https://github.com/4444j99" target="_blank" rel="me noopener noreferrer" class="contact__link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
      </section>
    </div>
</Layout>

<IndexFilters />

<style>
  /* --- Paired sections: side-by-side bento --- */
  .home-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    max-width: var(--max-width);
    margin: 0 auto var(--space-md);
    padding: 0 var(--space-lg);
  }

  .home-pair__contact {
    background: var(--bg-card);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .section__heading {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .contact__text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
  }

  .contact__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }

  .contact__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .contact__link:hover {
    color: var(--accent-text);
  }

  /* Override ConsultCTA spacing when inside the pair */
  .home-pair :global(.consult-cta) {
    padding: var(--space-xl);
    margin: 0;
    background: var(--bg-card);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  @media (max-width: 768px) {
    .home-pair {
      grid-template-columns: 1fr;
    }
  }
</style>
