---
import BentoGrid from '../components/home/BentoGrid.astro';
import BentoProjectCard from '../components/home/BentoProjectCard.astro';
import ContactBento from '../components/home/ContactBento.astro';
import HeroBento from '../components/home/HeroBento.astro';
import IndexFilters from '../components/home/IndexFilters.astro';
import PersonaBento from '../components/home/PersonaBento.astro';
import { organGroups } from '../data/organ-groups';
import personasData from '../data/personas.json';
import vitals from '../data/vitals.json';
import Layout from '../layouts/Layout.astro';
import { base } from '../utils/paths';

// Flatten all projects and take the first 8 for the bento grid
const allProjects = organGroups.flatMap((group) =>
	group.projects.map((p) => ({ ...p, href: `${base}projects/${p.slug}/` })),
);
const featured = allProjects.slice(0, 8);
const large = featured.slice(0, 2);
const small = featured.slice(2, 8);
---

<Layout
	title="Anthony James Padavano — AI Orchestration Architect"
	mainAttrs={{ 'data-portfolio-view': 'engineering' }}
	keywords={[
		'AI Orchestration',
		'Systems Architect',
		'Platform Governance',
		'Logocentric Architecture',
		'Staff Engineer',
		'Multi-Agent Systems',
		'Python',
		'TypeScript',
		'CI/CD Automation',
	]}
>
	<BentoGrid>
		<HeroBento vitals={vitals} />
		{large.map((p) => (
			<BentoProjectCard
				title={p.title}
				tagline={p.tagline}
				href={p.href}
				tags={p.tags}
				size="large"
				slug={p.slug}
			/>
		))}
		<PersonaBento personas={personasData.personas} />
		{small.map((p) => (
			<BentoProjectCard
				title={p.title}
				tagline={p.tagline}
				href={p.href}
				tags={p.tags}
				size="small"
				slug={p.slug}
			/>
		))}
		<ContactBento />
	</BentoGrid>
</Layout>

<IndexFilters />
