---
import { SKETCH_NAMES } from '@4444j99/sketches';
import BentoGrid from '../components/home/BentoGrid.astro';
import ConsultCTA from '../components/home/ConsultCTA.astro';
import HeroSection from '../components/home/HeroSection.astro';
import IndexFilters from '../components/home/IndexFilters.astro';
import PersonaCards from '../components/home/PersonaCards.astro';
import ProjectGrid from '../components/home/ProjectGrid.astro';
import { organColorMap } from '../data/organ-colors';
import { categoryFilters, featuredNumbers, organGroups, skillFilters } from '../data/organ-groups';
import personasData from '../data/personas.json';
import vitals from '../data/vitals.json';
import Layout from '../layouts/Layout.astro';
import { base } from '../utils/paths';

// Resolve slugs to full hrefs at build time
const resolvedGroups = organGroups.map((group) => ({
	...group,
	projects: group.projects.map((p) => ({ ...p, href: `${base}projects/${p.slug}/` })),
}));
---

<Layout
	title="Anthony James Padavano — AI Orchestration Architect"
	mainAttrs={{ 'data-portfolio-view': 'engineering' }}
	keywords={[
		'AI Orchestration',
		'Systems Architect',
		'Platform Governance',
		'Logocentric Architecture',
		'Staff Engineer',
		'Multi-Agent Systems',
		'Python',
		'TypeScript',
		'CI/CD Automation',
	]}
>
	<BentoGrid>
		<div class="bento-cell--hero">
			<HeroSection resolvedGroups={resolvedGroups} />
		</div>

		<div class="bento-cell--personas">
			<PersonaCards personas={personasData.personas} />
		</div>

		<div class="bento-cell--stats">
			<div class="stat-grid" data-stats-view="engineering" data-reveal>
				<div class="stat">
					<div class="stat-value">{vitals.substance.code_files.toLocaleString()}</div>
					<div class="stat-label">Code Files</div>
				</div>
				<div class="stat">
					<div class="stat-value">{vitals.substance.test_files}</div>
					<div class="stat-label">Test Files</div>
				</div>
				<div class="stat">
					<div class="stat-value">{vitals.substance.ci_passing}</div>
					<div class="stat-label">Passing CI Workflows</div>
				</div>
				<div class="stat">
					<div class="stat-value">{vitals.repos.total}</div>
					<div class="stat-label">Repositories</div>
				</div>
				<div class="stat">
					<div class="stat-value">{vitals.substance.automated_tests.toLocaleString()}+</div>
					<div class="stat-label">Automated Tests</div>
				</div>
			</div>
			<div class="stat-grid" data-stats-view="creative" style="display: none;">
				<div class="stat">
					<div class="stat-value">{vitals.repos.total}</div>
					<div class="stat-label">Repositories</div>
				</div>
				<div class="stat">
					<div class="stat-value">{vitals.repos.orgs}</div>
					<div class="stat-label">Organizations</div>
				</div>
				<div class="stat">
					<div class="stat-value">{Math.floor(vitals.logos.words / 1000)}K</div>
					<div class="stat-label">Words Documented</div>
				</div>
				<div class="stat">
					<div class="stat-value">{vitals.logos.essays}</div>
					<div class="stat-label">Published Essays</div>
				</div>
				<div class="stat">
					<div class="stat-value">{SKETCH_NAMES.length}</div>
					<div class="stat-label">Generative Sketches</div>
				</div>
			</div>
		</div>

		<div class="bento-cell--projects">
			<ProjectGrid
				resolvedGroups={resolvedGroups}
				skillFilters={skillFilters}
				categoryFilters={categoryFilters}
				featuredNumbers={featuredNumbers}
				organColorMap={organColorMap}
			/>
		</div>

		<div class="bento-cell--cta">
			<ConsultCTA />
		</div>

		<div class="bento-cell--contact">
			<section class="contact-inner" id="contact">
				<h2 class="section__heading">Strategic Orchestration</h2>
				<p class="contact__text">
					I bridge 15 years of high-stakes delivery with modern system orchestration. I am
					available for Staff and Director-level roles in AI Infrastructure, Systems
					Architecture, and Creative R&D.
				</p>
				<div class="contact__links">
					<a href="mailto:padavano.anthony@gmail.com" class="contact__link">
						<svg
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
							><rect x="2" y="4" width="20" height="16" rx="2"></rect><path
								d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
						>
						padavano.anthony@gmail.com
					</a>
					<a
						href="https://www.linkedin.com/in/anthony-james-padavano-98a40a186/"
						target="_blank"
						rel="me noopener noreferrer"
						class="contact__link"
					>
						<svg
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="currentColor"
							aria-hidden="true"
							><path
								d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
							></path></svg
						>
						LinkedIn
					</a>
					<a
						href="https://github.com/4444j99"
						target="_blank"
						rel="me noopener noreferrer"
						class="contact__link"
					>
						<svg
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="currentColor"
							aria-hidden="true"
							><path
								d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
							></path></svg
						>
						GitHub
					</a>
				</div>
			</section>
		</div>
	</BentoGrid>
</Layout>

<IndexFilters />

<style>
	/* Bento cell grid spans */
	.bento-cell--hero {
		grid-column: span 8;
	}

	.bento-cell--personas {
		grid-column: span 4;
	}

	.bento-cell--stats {
		grid-column: span 12;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-lg);
		backdrop-filter: blur(16px);
	}

	.bento-cell--projects {
		grid-column: span 12;
	}

	.bento-cell--cta {
		grid-column: span 6;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-lg);
		backdrop-filter: blur(16px);
	}

	.bento-cell--contact {
		grid-column: span 6;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-lg);
		backdrop-filter: blur(16px);
	}

	/* Stats */
	.stat-grid {
		display: flex;
		justify-content: space-around;
		gap: var(--space-lg);
		flex-wrap: wrap;
	}

	.stat {
		text-align: center;
		min-width: 120px;
	}

	.stat-value {
		font-family: var(--font-heading);
		font-size: 1.8rem;
		font-weight: 700;
		color: var(--accent-text);
		line-height: 1.2;
	}

	.stat-label {
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-muted);
		margin-top: var(--space-xs);
	}

	/* Contact */
	.contact-inner {
		padding: var(--space-md) 0;
	}

	.section__heading {
		font-family: var(--font-heading);
		margin-bottom: var(--space-xl);
	}

	.contact__text {
		font-size: 1.05rem;
		line-height: 1.7;
		margin-bottom: var(--space-xl);
		max-width: 50ch;
		color: var(--text-secondary);
	}

	.contact__links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-lg);
	}

	.contact__link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-sm);
		font-size: 0.95rem;
		color: var(--text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.contact__link:hover {
		color: var(--accent-text);
	}

	/* Mobile: all cells full width */
	@media (max-width: 768px) {
		.bento-cell--hero,
		.bento-cell--personas,
		.bento-cell--stats,
		.bento-cell--projects,
		.bento-cell--cta,
		.bento-cell--contact {
			grid-column: span 12;
		}

		.stat-grid {
			gap: var(--space-md);
		}

		.stat {
			min-width: 80px;
		}

		.stat-value {
			font-size: 1.4rem;
		}
	}
</style>
