---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const pathos = await getCollection('pathos');
  return pathos.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout
  title={entry.data.title}
  description={entry.data.hookLine}
>
  <article class="pathos-article">
    <div class="container pathos-container">
      <header class="pathos-header">
        <a href="/portfolio/pathos/" class="back-link">&larr; Back to Pathos</a>
        <h1 class="pathos-title">{entry.data.title}</h1>
        <div class="pathos-meta">
          <time datetime={entry.data.date.toISOString()}>
            {entry.data.date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        </div>
        <p class="pathos-context">{entry.data.context}</p>
        <div class="voice-legend">
          <div class="voice voice--human">
            <span class="voice__label">Artifex</span>
            <span class="voice__desc">{entry.data.voices.human}</span>
          </div>
          <div class="voice voice--ai">
            <span class="voice__label">Mercurius</span>
            <span class="voice__desc">{entry.data.voices.ai}</span>
          </div>
        </div>
        <p class="collaboration-notice">
          This is a human-AI collaboration artifact — a real conversation from a real working session, edited for arc but not for voice.
        </p>
      </header>

      <div class="dialogue-body">
        <Content />
      </div>

      {entry.data.artifacts.length > 0 && (
        <footer class="pathos-labyrinth">
          <h2 class="labyrinth-heading">The Labyrinth</h2>
          <p class="labyrinth-desc">The systems, repositories, and artifacts surrounding this conversation. Evidence that the words above are attached to real work.</p>
          <div class="labyrinth-links">
            {entry.data.artifacts.map(artifact => (
              <a
                href={artifact.url}
                class={`labyrinth-link labyrinth-link--${artifact.type}`}
                {...(artifact.url.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                <span class="labyrinth-link__type">{artifact.type}</span>
                <span class="labyrinth-link__label">{artifact.label}</span>
              </a>
            ))}
          </div>
        </footer>
      )}
    </div>
  </article>
</Layout>

<style>
  .pathos-article {
    padding: var(--space-3xl) 0;
  }

  .pathos-container {
    max-width: 720px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: var(--space-xl);
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--accent);
  }

  .pathos-title {
    font-size: 2.5rem;
    line-height: 1.1;
    margin-bottom: var(--space-md);
    letter-spacing: -0.02em;
  }

  .pathos-meta {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
  }

  .pathos-context {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-xl);
    font-style: italic;
  }

  .voice-legend {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
    padding: var(--space-lg);
    background: var(--bg-secondary);
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }

  .voice {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
  }

  .voice__label {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9rem;
    min-width: 7ch;
  }

  .voice--human .voice__label {
    color: var(--text-primary);
  }

  .voice--ai .voice__label {
    color: var(--accent);
  }

  .voice__desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .collaboration-notice {
    font-size: 0.8rem;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  /* --- Dialogue Rendering --- */
  .dialogue-body {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text-primary);
  }

  /* Speaker labels — paragraphs that contain only a bold name */
  .dialogue-body :global(p > strong:only-child) {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: var(--space-2xl);
    margin-bottom: 0;
    padding-top: var(--space-xl);
    border-top: 1px solid var(--border);
  }

  /* First speaker label — no top border */
  .dialogue-body :global(p:first-child > strong:only-child) {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  /* Color Artifex and Mercurius differently */
  .dialogue-body :global(p > strong:only-child) {
    color: var(--text-primary);
  }

  /* Dialogue text */
  .dialogue-body :global(p) {
    margin-bottom: 1.2em;
  }

  /* Lists within dialogue */
  .dialogue-body :global(ul),
  .dialogue-body :global(ol) {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
  }

  .dialogue-body :global(li) {
    margin-bottom: 0.5em;
    line-height: 1.6;
  }

  /* --- Labyrinth (artifacts footer) --- */
  .pathos-labyrinth {
    margin-top: var(--space-3xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--border);
  }

  .labyrinth-heading {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .labyrinth-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: var(--space-xl);
    max-width: 55ch;
  }

  .labyrinth-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .labyrinth-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.4em 0.8em;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm, 4px);
    color: var(--text-secondary);
    text-decoration: none;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .labyrinth-link:hover {
    border-color: var(--accent);
    color: var(--text-primary);
  }

  .labyrinth-link__type {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    opacity: 0.7;
  }

  .labyrinth-link--repo .labyrinth-link__type {
    color: var(--accent-green, #00e676);
  }

  .labyrinth-link--system .labyrinth-link__type {
    color: var(--accent, #d4a853);
  }

  .labyrinth-link--artifact .labyrinth-link__type {
    color: var(--accent-purple, #9c27b0);
  }

  @media (max-width: 768px) {
    .pathos-title {
      font-size: 1.8rem;
    }

    .voice-legend {
      padding: var(--space-md);
    }

    .voice {
      flex-direction: column;
      gap: var(--space-2xs);
    }
  }
</style>
